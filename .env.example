# CliUpload Configuration
# Copy this file to .env and configure your settings

# Database Configuration
DB_HOST=localhost
DB_NAME=cliupload
DB_USER=cliupload_user
DB_PASS=your_secure_password_here
DB_CHARSET=utf8mb4

# Admin Configuration
ADMIN_USERNAME=admin
# Generate a secure password hash using: php -r "echo password_hash('your_password', PASSWORD_DEFAULT);"
ADMIN_PASSWORD_HASH=$2y$10$92IXUNpkjO0rOQ5byMi.Ye4oKoEa3Ro9llC/.og/at2.uheWG/igi

# Upload Directory (absolute path)
UPLOAD_DIR=/var/www/cliupload.com/uploads/

# Security Settings
SESSION_LIFETIME=3600
CSRF_TOKEN_LIFETIME=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_UPLOADS_PER_HOUR=20
RATE_LIMIT_DOWNLOADS_PER_HOUR=100
RATE_LIMIT_ADMIN_LOGIN_ATTEMPTS=5
RATE_LIMIT_BLOCK_DURATION=1800

# File Settings
MAX_FILE_SIZE=2147483648
MAX_PREVIEW_SIZE=1048576

# Logging
ERROR_LOG_ENABLED=true
ERROR_LOG_FILE=/var/www/cliupload.com/logs/error.log
ACTIVITY_LOG_ENABLED=true

# Development Mode (set to false in production)
DEBUG_MODE=false
DISPLAY_ERRORS=false
